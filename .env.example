# Ollama LLM-Konfiguration
OLLAMA_URL=http://localhost:11434
LLM_MODEL=qwen3:8b

# Qwen3-TTS Modell (vollständige HuggingFace Repo-ID)
#
# Optionen (kein Referenz-Audio nötig):
#   Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign   → Stimme per Text beschreiben (Empfehlung)
#   Qwen/Qwen3-TTS-12Hz-0.6B-VoiceDesign   → kleineres Modell, weniger VRAM
#   Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice   → vordefinierte Sprecher
#
# Nur mit Referenz-Audio:
#   Qwen/Qwen3-TTS-12Hz-1.7B-Base          → Voice Cloning (TTS_REF_AUDIO erforderlich)
#
TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign

# Nur für VoiceDesign: Stimmbeschreibung der Stimme/des Vorlesestils
TTS_VOICE_INSTRUCT=Speak as a professional audiobook narrator: warm, clear, and unhurried. Use a steady, measured pace with natural pauses at punctuation. Apply subtle emphasis on key words without theatrical exaggeration. Maintain a consistent, engaging tone — inviting the listener to follow along as if reading aloud from a well-loved book.

# Nur für CustomVoice: Sprecher-Name
TTS_SPEAKER=Vivian

# Nur für Base (Voice Cloning): Pfad zum Referenz-WAV und dessen Transkription
TTS_REF_AUDIO=
TTS_REF_TEXT=

# Inferenz-Gerät: cuda | cuda:0 | cpu
TTS_DEVICE=cuda

# Seed für VoiceDesign — fixiert den Random-State vor jedem Chunk für konsistente Stimme.
# Leer lassen = automatisch aus Buchtitel abgeleitet (empfohlen).
# Zahl setzen = erzwingt diesen Seed (nützlich um eine bestimmte Stimme zu wiederholen).
TTS_SEED=

# Ausgabeverzeichnis
OUTPUT_DIR=./output

# Max. Zeichen pro TTS-Aufruf (nur an Satzgrenzen trennen)
TTS_CHUNK_SIZE=3000
